OPENAI_API_KEY=openai-api-key
COHERE_API_KEY=cohere-api-key
WEAVIATE_URL=http://localhost:8080

# Git commit of the running build (set automatically in Docker/Makefile/dev script)
# GIT_COMMIT=abc123

# Optional [LangSmith](https://smith.langchain.com/) tracing for OpenAI chat completions:
LANGSMITH_TRACING=false         # set to true to enable
LANGSMITH_API_KEY=langsmith-api-key
LANGSMITH_PROJECT=my-project    # defaults to "default"
